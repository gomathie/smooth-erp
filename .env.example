# Rename this file to .env and update values for your local environment.
DB_HOST=localhost
DB_NAME=posystem
DB_USER=root
DB_PASS=
DB_CHARSET=utf8
APP_NAME="Smooth ERP"
APP_ENV=development
APP_DEBUG=true

# SMTP settings for password reset emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your-smtp-username@example.com
SMTP_PASSWORD=change-this-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME="Smooth ERP"
SMTP_TIMEOUT=15
